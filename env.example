# Configuración de Django
# Producción: DEBUG=False SIEMPRE (con True se filtran trazas, SQL y settings).
DEBUG=False
SECRET_KEY=tu_clave_secreta_aqui_cambiar_en_produccion

# Configuración de Base de Datos PostgreSQL (Docker)
name_db=sive_db
user_postgres=tu_usuario_postgres
password_user_postgres=tu_password_postgres_seguro
port_postgres=5432

# Configuración de Redis (Docker)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=tu_password_redis_seguro

# Debe coincidir con el nombre del servicio de la BD en docker-compose (db)
POSTGRES_HOST=db

# Configuración de SCADA
SCADA_BASE_URL=http://192.68.185.76:3700
SCADA_USERNAME=tu_usuario_scada
SCADA_PASSWORD=tu_password_scada

# API XM (pydataxm): verificación SSL. Solo usar false si hay proxy/cortafuegos que rompe SSL
# PYDATAXM_VERIFY_SSL=false

# Configuración de hosts permitidos (INCLUYE localhost Y IP real)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,TU_IP_AQUI

# Configuración de CORS (INCLUYE localhost Y IP real)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3503,http://127.0.0.1:3503,http://TU_IP_AQUI,http://TU_IP_AQUI:3503

# Orígenes de confianza para CSRF (requerido por Django para POST cross-origin, p. ej. /admin)
CSRF_TRUSTED_ORIGINS=http://TU_IP_AQUI:3503,http://TU_IP_AQUI:3504,http://localhost:3503,http://localhost:3504

# Configuración de zona horaria
TIME_ZONE=America/Bogota

# URLs para el frontend (CAMBIAR localhost por tu IP)
REACT_APP_API_URL=http://TU_IP_AQUI:3504
REACT_APP_FRONTEND_URL=http://TU_IP_AQUI:3503

# Configuración de dominio (CAMBIAR localhost por tu IP)
DOMAIN_NAME=TU_IP_AQUI

# Configuración de puertos personalizados
FRONTEND_PORT=3503
BACKEND_PORT=3504

# =============================================================================
# Despliegue HTTPS bajo subpath detrás de Apache (ver deploy/apache-sive.conf
# y DEPLOY_SIVE_SUBPATH.md). Descomentar y ajustar para servir en
# https://mte.udenar.edu.co/sive/  (reusa el certificado del dominio).
# =============================================================================
# ALLOWED_HOSTS=localhost,127.0.0.1,mte.udenar.edu.co
# CORS_ALLOWED_ORIGINS=https://mte.udenar.edu.co
# CSRF_TRUSTED_ORIGINS=https://mte.udenar.edu.co
# REACT_APP_API_URL=https://mte.udenar.edu.co/sive
#
# Django bajo el prefijo /sive (genera admin/login/redirecciones con el prefijo):
# FORCE_SCRIPT_NAME=/sive
# STATIC_URL=/sive/django-static/
# USE_X_FORWARDED_HOST=True
# BEHIND_TLS_PROXY=True          # activa SECURE_PROXY_SSL_HEADER (Apache setea X-Forwarded-Proto)
#
# HSTS: dejar en 0. El dominio es COMPARTIDO con otras apps; el HSTS debe
# gestionarlo Apache a nivel de dominio, no esta app.
# SECURE_HSTS_SECONDS=0

# Configuración adicional (opcional)
password_postgres=tu_password_postgres_adicional
username_SIVE=tu_usuario_sive
password_SIVE=tu_password_sive
wsl_account=tu_cuenta_wsl
wsl_password=tu_password_wsl
start_worker_celery=celery -A core worker -l info -P gevent
start_celery_beat=celery -A core beat -l info --scheduler django_celery_beat.schedulers:DatabaseScheduler

# Configuración de Producción (opcional)
# DEBUG=False
# ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,TU_IP_AQUI
# FRONTEND_PORT=3503
# BACKEND_PORT=3504
# REACT_APP_API_URL=http://TU_IP_AQUI:3504
# REACT_APP_FRONTEND_URL=http://TU_IP_AQUI:3503
# DOMAIN_NAME=TU_IP_AQUI
